# Agent runtime
AGENT_ENVIRONMENT=DEV

# Lookback window (minutes) — retrieve errors from last N minutes
# Rule: lookback_minutes >= POLL_INTERVAL_seconds / 60 * 2
# Default: 5 minutes (safe for first run, avoid processing old failures)
# Set -1 to disable time filter (manual backfill mode only)
AGENT_LOOKBACK_MINUTES=5

# Poll interval (seconds) — time between consecutive error checks
# Default: 60 seconds (1 minute)
# Note: Ensure lookback_minutes >= 2 * (poll_interval / 60)
AGENT_POLL_INTERVAL=30

# Phase 2 — Retry config
# Lay processor ID: NiFi UI -> GenerateFlowFile Luong 3 -> right click -> Copy ID
NIFI_LUONG3_PROCESSOR_ID=60a5f95b-5a92-3439-089c-b72ecf34b99b

# RETRY CONFIG
RETRY_ENABLED=true

# Max retries: thay doi bat ky luc nao ma khong can sua code
MAX_RETRIES=3

# --- RETRY CONFIG ---
# BIEN 1: confirmed_new_failure_minutes
# Buffer so sanh end_time(loi moi) vs last_retry_at
# Dat = thoi gian Bronze job chay nhanh nhat + 1 phut buffer
# Vi du Bronze min=3min -> dat CONFIRMED_NEW_FAILURE_MINUTES=4
CONFIRMED_NEW_FAILURE_MINUTES=1

# BIEN 2: fallback_delay_minutes
# Chi dung khi timestamp bi NULL/loi parse
# Dat >= CONFIRMED_NEW_FAILURE_MINUTES
FALLBACK_DELAY_MINUTES=5

# Tong window retry (phut)
MAX_RETRY_WINDOW_MINUTES=50
