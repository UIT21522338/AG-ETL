# Agent runtime
AGENT_ENVIRONMENT=DEV

# Lookback window (minutes) — retrieve errors from last N minutes
# Rule: lookback_minutes >= POLL_INTERVAL_seconds / 60 * 2
# Default: 10 minutes (safe for poll_interval=60s)
# Set -1 to disable time filter (manual backfill mode only)
AGENT_LOOKBACK_MINUTES=10

# Poll interval (seconds) — time between consecutive error checks
# Default: 60 seconds (1 minute)
# Note: Ensure lookback_minutes >= 2 * (poll_interval / 60)
AGENT_POLL_INTERVAL=60
